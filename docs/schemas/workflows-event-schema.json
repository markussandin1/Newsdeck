{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Newsdeck Workflows Event",
  "description": "Schema för POST /api/workflows. Antingen columnId eller workflowId krävs. Antingen item eller items krävs.",
  "type": "object",
  "properties": {
    "columnId": {
      "type": "string",
      "description": "UUID för målkolumnen (rekommenderat). Hittas i kolumnens inställningar i UI:t."
    },
    "workflowId": {
      "type": "string",
      "description": "Äldre identifierare (fasas ut). Matchas mot kolumners flowId-fält."
    },
    "item": {
      "type": "object",
      "description": "Enskilt nyhetsobjekt (rekommenderat format).",
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Rubrik. Enda obligatoriska fältet."
        },
        "id": {
          "type": "string",
          "description": "Källans eget ID (valfritt, ej unikt – används för deduplicering inom kolumn)."
        },
        "source": {
          "type": "string",
          "description": "Källnamn, t.ex. Trafikverket, Polisen, SOS Alarm. Default: workflows."
        },
        "url": {
          "type": "string",
          "description": "Länk till källa eller artikel."
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601-tidsstämpel, t.ex. 2026-03-23T10:30:00Z. Default: serverns tid."
        },
        "description": {
          "type": "string",
          "description": "Fritext beskrivning av händelsen."
        },
        "newsValue": {
          "type": "number",
          "description": "Nyhetsvärde 1–5. 5 = högst prioritet (röd pulsande ram). Default: 3.",
          "minimum": 1,
          "maximum": 5
        },
        "category": {
          "type": "string",
          "description": "Händelsekategori, t.ex. trafikolycka, brand, vägarbete."
        },
        "severity": {
          "type": "string",
          "description": "Allvarlighetsgrad – fri textsträng, t.ex. Allvarlig. Kan vara null.",
          "nullable": true
        },
        "location": {
          "type": "object",
          "description": "Geografisk information.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Fritext platsnamn, t.ex. E4 vid Rotebro."
            },
            "county": {
              "type": "string",
              "description": "Länsnamn i fritext, t.ex. Stockholms län."
            },
            "municipality": {
              "type": "string",
              "description": "Kommunnamn i fritext, t.ex. Stockholm."
            },
            "countryCode": {
              "type": "string",
              "description": "ISO 3166-1 alpha-2 landskod, exakt 2 versaler, t.ex. SE. Krävs för geo-filtrering."
            },
            "regionCode": {
              "type": "string",
              "description": "SCB länskod, exakt 2 siffror, t.ex. 01 för Stockholm, 24 för Västerbotten."
            },
            "municipalityCode": {
              "type": "string",
              "description": "SCB kommunkod, exakt 4 siffror, t.ex. 0180 för Stockholm."
            },
            "coordinates": {
              "type": "array",
              "description": "Koordinater [lat, lon] som tal, t.ex. [59.5, 17.9].",
              "items": {
                "type": "number"
              },
              "minItems": 2,
              "maxItems": 2
            },
            "regionGeoId": {
              "type": "string",
              "description": "UUID från Bonniers geo-service för regionen."
            },
            "regionName": {
              "type": "string",
              "description": "Regionnamn från geo-service."
            },
            "municipalityGeoId": {
              "type": "string",
              "description": "UUID från Bonniers geo-service för kommunen."
            },
            "municipalityName": {
              "type": "string",
              "description": "Kommunnamn från geo-service."
            }
          },
          "additionalProperties": true
        },
        "extra": {
          "type": "object",
          "description": "Valfria extra-fält för detta item.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "description": "Array av nyhetsobjekt (äldre format). Samma struktur som item.",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "id": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string" },
          "timestamp": { "type": "string" },
          "description": { "type": "string" },
          "newsValue": { "type": "number", "minimum": 1, "maximum": 5 },
          "category": { "type": "string" },
          "severity": { "type": "string", "nullable": true },
          "location": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "county": { "type": "string" },
              "municipality": { "type": "string" },
              "countryCode": { "type": "string" },
              "regionCode": { "type": "string" },
              "municipalityCode": { "type": "string" },
              "coordinates": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              },
              "regionGeoId": { "type": "string" },
              "regionName": { "type": "string" },
              "municipalityGeoId": { "type": "string" },
              "municipalityName": { "type": "string" }
            },
            "additionalProperties": true
          },
          "extra": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "extra": {
      "type": "object",
      "description": "Extra-fält som appliceras på alla items i requesten.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
