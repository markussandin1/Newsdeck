# NewsDeck Environment Variables

# ===================================
# Database Configuration
# ===================================

# PostgreSQL Database URL
# For local development with Docker:
DATABASE_URL=postgresql://newsdeck:newsdeck_local@localhost:5433/newsdeck_dev

# For production (Cloud SQL, Supabase, etc.):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===================================
# Rate Limiting
# ===================================

# Rate limiting uses PostgreSQL (DATABASE_URL above)
# No additional configuration needed!
# Current limit: 100 requests per minute per workflow
# Adjust in lib/rate-limit.ts if needed

# ===================================
# Development Settings
# ===================================

# Set to 'development' for local dev, 'production' for prod
NODE_ENV=development

# API Key for securing endpoints (optional for local dev)
# API_KEY=your_secret_api_key_here

# ===================================
# Pub/Sub push subscription auth (production)
# ===================================
# Required in production to verify Google Cloud Pub/Sub push tokens for
# /api/pubsub/news-items. Without these the endpoint will reject all pushes
# and real-time SSE updates will stop.
#
# PUBSUB_PUSH_AUDIENCE matches the "audience" configured on the push
# subscription (typically the Cloud Run service URL).
# PUBSUB_PUSH_SERVICE_ACCOUNT (optional) restricts which service-account
# may push; leave unset to accept any valid GCP-signed OIDC token.
# PUBSUB_PUSH_AUDIENCE=https://newsdeck-389280113319.europe-west1.run.app/api/pubsub/news-items
# PUBSUB_PUSH_SERVICE_ACCOUNT=pubsub-push@newsdeck-473620.iam.gserviceaccount.com
